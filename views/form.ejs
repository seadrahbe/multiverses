<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/styles/particles.css" type="text/css">
    <link rel="stylesheet" href="/styles/nav.css" type="text/css" />
    <link rel="stylesheet" href="styles/form.css" type="text/css" />
    <script src="/js/form.js" defer></script>
    <title>Poem</title>
  </head>
  <body>
    <!-- particles.js container --> 
    <div id="particles-js"></div> 
    <!-- particles.js lib - https://github.com/VincentGarreau/particles.js for the library!-->
    <header>
      <h1 id="main-title">MultiVerses</h1>
      <%- include('partials/nav.ejs') %>
    </header>
    <main>
      <form id="submit_form" action="/submit-poem" method="post">
        <fieldset class="poem_info">
          <!-- <label for="author"> Author: </label> -->
          <!-- In order to not include labels, but still be accesible, you have to include an aria
            label inside of the input -->
          <span class="err" id="err-author">
            Author is required. If unknown, put "unknown".
          </span>
          <input
            type="text"
            id="author"
            name="author"
            placeholder="Author:"
            aria-label="Author"
          />

          <!-- <label for="title"> Title: </label> -->
          <span class="err" id="err-title">
            Title is required. If unknown, put "unknown".</span
          >
          <input
            type="text"
            id="title"
            name="title"
            placeholder="Title:"
            aria-label="Title"
          />
        </fieldset>
        <fieldset class="poem_info row_2">
          <!-- <label for="tags"> Tags: </label> -->
          <div>
            <input
              type="text"
              id="tags"
              placeholder="#Tags"
              aria-label="Tags"
              autocomplete="off"
            />
          </div>

          <!-- <label for="date"> Date of Creation: </label> -->
           <div>
            <!-- .toISOString is a JS Date object method that returns a string representation of the date if you were curious! -->
            <input
              type="date"
              id="date"
              name="date"
              aria-label="Date of Creation"
              value="<%= new Date().toISOString().substring(0, 10) %>"
            />
           </div>
          
        </fieldset>

        <div id="tag-container"></div>
        <input type=text id="hidden-tag-input" name = 'tags'>

        <fieldset id="poem_content">
          <!-- <label for="poem">Poem:</label> -->
          <span class="err" id="err-poem"> Please enter a poem. </span>
          <textarea
            rows="5"
            id="poem"
            name="poem"
            placeholder="Write your beautiful magic here..."
            aria-label="Poem:"
          ></textarea>
        </fieldset>
        <button type="submit" id="submit_button">Submit</button>
      </form>
    </main>
    <footer></footer>
    <script src="http://cdn.jsdelivr.net/particles.js/2.0.0/particles.min.js"></script> 
    <script src="/js/stars.js" defer></script>
  </body>
</html>
